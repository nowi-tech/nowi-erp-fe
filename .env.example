VITE_API_URL=http://localhost:3001

# Sentry — match the names set by the Sentry-Vercel integration so the same
# values work locally and in Vercel without renaming.
# DSN is safe to commit, but leave blank in local dev to silence Sentry.

# Source-map upload (build-time only). When SENTRY_AUTH_TOKEN is empty the
# upload step is a no-op, so local builds still work.
SENTRY_ORG=nowi
SENTRY_PROJECT=javascript-react
SENTRY_AUTH_TOKEN=
